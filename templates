<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Tour Trip One Day in Kanchanaburi</title>
    <!-- นำเข้าฟอนต์ Prompt เพื่อความโมเดิร์น -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #e0e5ec;
            --text-color: #313b4c;
            --glass-bg: rgba(255, 255, 255, 0.45);
            --glass-border: rgba(255, 255, 255, 0.25);
            /* Neumorphism Shadow Effect */
            --neu-shadow-out: 9px 9px 16px #b8b9be, -9px -9px 16px #ffffff;
            --neu-shadow-in: inset 3px 3px 7px #b8b9be, inset -3px -3px 7px #ffffff;
        }

        body {
            font-family: 'Prompt', sans-serif;
            background: linear-gradient(135deg, #f0f4f8 0%, #e0e5ec 100%);
            color: var(--text-color);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Header ดีไซน์ Glassmorphism */
        header {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 30px;
            text-align: center;
            box-shadow: var(--neu-shadow-out);
            margin-bottom: 40px;
        }

        header h1 {
            margin: 0;
            font-size: 2rem;
            font-weight: 600;
            background: linear-gradient(45deg, #2c3e50, #4a69bd);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1rem;
        }

        header p {
            margin: 10px 0 0 0;
            color: #616e7f;
            font-weight: 300;
        }

        /* Grid การ์ดสถานที่ */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
            margin-bottom: 50px;
        }

        /* ผสมผสาน Glassmorphism (พื้นหลังใสขุ่น) + Neumorphism (ขอบและเงา) */
        .card {
            background: var(--glass-bg);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--neu-shadow-out);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .card-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .card-content {
            padding: 25px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .card-title {
            margin: 0 0 12px 0;
            font-size: 1.25rem;
            font-weight: 500;
        }

        .card-desc {
            font-size: 0.95rem;
            color: #556375;
            line-height: 1.6;
            margin-bottom: 20px;
            font-weight: 300;
        }

        /* ปุ่มนำทางสไตล์ Neumorphism แบบนุ่มนวล */
        .btn-route {
            display: block;
            text-align: center;
            padding: 12px 20px;
            background: var(--bg-color);
            color: var(--text-color);
            text-decoration: none;
            border-radius: 12px;
            font-weight: 500;
            box-shadow: var(--neu-shadow-out);
            transition: all 0.2s ease;
            border: 1px solid rgba(255,255,255,0.5);
        }

        .btn-route:hover {
            box-shadow: var(--neu-shadow-in);
            color: #1e3799;
        }

        /* Section แผนที่ด้านล่างสุด */
        .map-section {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 30px;
            box-shadow: var(--neu-shadow-out);
        }

        .map-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 20px;
        }

        .map-header h2 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 500;
        }

        /* ปุ่มหลัก Explore Route สไตล์ Neumorphism เด่นพิเศษ */
        .btn-explore-all {
            display: inline-flex;
            align-items: center;
            padding: 12px 28px;
            background: #4a69bd;
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 500;
            box-shadow: 4px 4px 10px rgba(74, 105, 189, 0.3), -4px -4px 10px rgba(255,255,255,0.8);
            transition: all 0.2s ease;
        }

        .btn-explore-all:hover {
            background: #3b59a6;
            transform: scale(1.02);
        }

        .map-container {
            border-radius: 16px;
            overflow: hidden;
            box-shadow: inset 2px 2px 5px rgba(0,0,0,0.1);
            border: 1px solid rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- Header -->
        <header>
            <h1>Mini Tour Trip One Day ในจังหวัดกาญจนบุรี</h1>
            <p>วางแผนการท่องเที่ยว 1 วัน สัมผัสธรรมชาติ มรดกโลก และสายน้ำแห่งเมืองกาญจน์</p>
        </header>

        <!-- รายการสถานที่ท่องเที่ยว -->
        <div class="grid">
            {% for loc in locations %}
            <div class="card">
                <img src="{{ loc.image_url }}" alt="{{ loc.name }}" class="card-image">
                <div class="card-content">
                    <div>
                        <h3 class="card-title">{{ loc.id }}. {{ loc.name }}</h3>
                        <p class="card-desc">{{ loc.description }}</p>
                    </div>
                    <!-- ปุ่มข้อมูลเส้นทางรายสถานที่เชื่อมไป Google Maps ด้วยพิกัด -->
                    <a href="https://www.google.com/maps/search/?api=1&query={{ loc.lat }},{{ loc.lng }}" 
                       target="_blank" 
                       class="btn-route">
                       📍 ข้อมูลเส้นทาง
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>

        <!-- ส่วนแสดงผลแผนที่ด้านล่างสุดตามเงื่อนไข -->
        <div class="map-section">
            <div class="map-header">
                <h2>🗺️ แผนที่จำลองเส้นทางท่องเที่ยว</h2>
                <!-- ปุ่มนำทางภาพรวมทริป (Explore Route) ลิงก์เข้าแผนที่หลัก -->
                <a href="https://www.google.com/maps/dir/15.1010826580672,98.7940648371254/14.508931824691606,98.98357900494995/14.426487828764621,99.28295643143015/14.412508671129645,99.14583856749876/14.36289162990611,99.1502339099092" 
                   target="_blank" 
                   class="btn-explore-all">
                   Explore Route (เปิดเส้นทางทริป)
                </a>
            </div>
            <div class="map-container">
                {{ map_html | safe }}
            </div>
        </div>
    </div>

</body>
</html>
